# ═══════════════════════════════════════════════════════════
#  Digital Sarathi v1.0 — Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── LLM: Groq (FREE — https://console.groq.com) ──────────
# Sign up → API Keys → Create key → paste below
GROQ_API_KEY=your_groq_api_key_here

# ─── Weather: OpenWeather (FREE — https://openweathermap.org/api)
# Sign up → My API keys → paste below
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── Database ──────────────────────────────────────────────
# Pick ONE option — comment out the others

# Option 1: MySQL (active — swap user/pass/host/dbname)
DATABASE_URL=mysql://root:your_password@localhost:3306/digital_sarathi

# Option 2: PostgreSQL (comment out MySQL above, uncomment this)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/digital_sarathi

# Option 3: Leave DATABASE_URL blank → uses SQLite (zero config, great for dev)
# DATABASE_URL=

# ─── Security ──────────────────────────────────────────────
# Any long random string — used for session signing
SECRET_KEY=change-this-to-a-long-random-string-in-production
